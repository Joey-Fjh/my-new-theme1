<section class="featured-products-section my-5">
  <div class="container">
    <h2 class="text-center mb-4">{{ section.settings.title }}</h2>
    <div class="row">
      {% assign collection_handle = section.settings.collection.handle | default: section.settings.collection %}
      {% assign collection = collections[collection_handle] %}
      
      {% if collection and collection.products.size > 0 %}
        {% assign products = collection.products | slice: 0, 8 %}
        <script>
          console.log({{ section.settings.collection }});
        </script>
        {% for product in products %}
          <div class="col-12 col-sm-6 col-md-3 mb-4 d-flex flex-column align-items-center">
            <a href="{{ product.url }}" class="w-100 mb-2" style="display:block;">
              {% if product.featured_image %}
                <img src="{{ product.featured_image | image_url: width: 400 }}" alt="{{ product.title }}" class="img-fluid rounded" style="aspect-ratio: 4/3; object-fit: cover; width:100%;" width="400" height="300">
              {% else %}
                <div class="bg-light d-flex align-items-center justify-content-center" style="height:200px;width:100%;">No Image</div>
              {% endif %}
            </a>
            <div class="product-title text-center mt-2">{{ product.title }}</div>
            <div class="product-price text-center text-muted mb-2">
              {{ product.price | money_with_currency }}
            </div>
          </div>
        {% endfor %}
      {% else %}
        <p class="text-center">No products found in this collection.</p>
      {% endif %}
    </div>
    <div class="text-center mt-3">
      <a href="{{ collection.url }}" class="btn btn-dark px-5 py-2">View all</a>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Featured Collection",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "Featured products"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection",
    }
  ],
  "presets": [
    {
      "name": "Featured Collection"
    }
  ]
}
{% endschema %}